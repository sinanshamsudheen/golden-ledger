# Golden Ledger – Backend Environment Variables
# Copy this file to .env and fill in your values

# ── PostgreSQL ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/golden_ledger

# ── Google OAuth ─────────────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key

# ── Security ─────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-string-in-production

# Fernet key for encrypting Google OAuth refresh tokens stored in the DB.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change-this-to-a-fernet-key-in-production

# ── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Invitus AI Insights (vectorizer) — optional ──────────────────────────────
# Leave these unset to disable the vectorization + analytical step entirely.
# The nightly worker will skip deal analysis when VECTORIZER_INGEST_URL is empty.

# Base URL for the document ingestion API (hosts /v1/api/ingestions, /v1/api/jobs/...)
VECTORIZER_INGEST_URL=https://your-ingestion-app.azurewebsites.net

# Base URL for the RAG gateway (hosts /api/Analytical) — may be the same host
VECTORIZER_ANALYTICAL_URL=https://your-rag-gateway.azurewebsites.net

# Azure Functions host key (used in x-functions-key header for both APIs)
VECTORIZER_FUNCTION_KEY=your-function-key-here

# Tenant ID assigned to your organisation by Invitus
VECTORIZER_TENANT_ID=your-tenant-id

# Optional overrides (defaults shown below)
# VECTORIZER_REGION=uae
# VECTORIZER_MODULE_ID=invictus-deals
# VECTORIZER_USE_CASE_ID=due-diligence
